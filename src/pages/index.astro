---
import Base from "../layouts/Base.astro";
---

<Base title="Form samples">
  <div class="wrap">
    <h1>Form samples</h1>
    <p class="desc">Demo pages for Spindigo Mailer multipart embeds (1, 2, and many fields).</p>
    <ul class="index-list">
      <li>
        <a href="/newsletter">Newsletter</a>
        <span>1 field — email</span>
      </li>
      <li>
        <a href="/quick-contact">Quick contact</a>
        <span>2 fields — name, email</span>
      </li>
      <li>
        <a href="/contact">Contact</a>
        <span>Many fields — name, email, message, optional attachment</span>
      </li>
    </ul>
  </div>
</Base>
