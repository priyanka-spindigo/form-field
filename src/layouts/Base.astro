---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline src="/mailer-form.js"></script>
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    font-family: system-ui, sans-serif;
    color: #1a1a1a;
    background: #fafafa;
  }
  .wrap {
    max-width: 28rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  .wrap h1 {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .wrap > p.desc {
    margin: 0 0 1.25rem;
    font-size: 0.875rem;
    color: #525252;
  }
  .back {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: #525252;
  }
  .field {
    margin-bottom: 1rem;
  }
  .field label {
    display: block;
    font-size: 0.875rem;
    margin-bottom: 0.35rem;
  }
  .field input[type="file"] {
    font-size: 0.875rem;
  }
  .field input:not([type="file"]),
  .field textarea {
    width: 100%;
    box-sizing: border-box;
    padding: 0.5rem 0.65rem;
    border: 1px solid #c9c9c9;
    border-radius: 6px;
    font: inherit;
  }
  .field textarea {
    min-height: 7rem;
    resize: vertical;
  }
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }
  button[type="submit"] {
    margin-top: 0.25rem;
    padding: 0.55rem 1.1rem;
    font: inherit;
    font-weight: 500;
    border: none;
    border-radius: 6px;
    background: #1a1a1a;
    color: #fff;
    cursor: pointer;
  }
  button[type="submit"]:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }
  .banner {
    margin-top: 1rem;
    font-size: 0.875rem;
    padding: 0.55rem 0.75rem;
    border-radius: 6px;
    line-height: 1.35;
  }
  .banner.hidden {
    display: none;
  }
  .index-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
  }
  .index-list li {
    margin-bottom: 0.75rem;
  }
  .index-list a {
    color: #1a1a1a;
    font-weight: 500;
  }
  .index-list span {
    display: block;
    font-size: 0.8125rem;
    color: #737373;
    font-weight: normal;
    margin-top: 0.15rem;
  }
</style>
